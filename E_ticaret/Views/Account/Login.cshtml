@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-lg rounded-4 p-4">
                <h3 class="fw-bold text-center mb-4">Giriş Yap</h3>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger py-2 small">@ViewBag.Error</div>
                }

                <form action="/Account/Login" method="post">
                    <div class="mb-3 text-start">
                        <label class="fw-bold small">E-Posta</label>
                        <input type="email" name="email" class="form-control rounded-pill border-2" placeholder="ornek@mail.com" required />
                    </div>
                    <div class="mb-3 text-start">
                        <label class="fw-bold small">Şifre</label>
                        <input type="password" name="sifre" class="form-control rounded-pill border-2" placeholder="******" required />
                    </div>
                    <button type="submit" class="btn btn-primary w-100 rounded-pill py-2 shadow fw-bold">Giriş Yap</button>
                </form>

                @* REGISTER BAĞLANTISI BURADA *@
                <div class="text-center mt-4">
                    <p class="text-muted small">
                        Henüz üye değil misiniz?
                        <a href="/Account/Register" class="text-primary fw-bold text-decoration-none ms-1">Hemen Kayıt Ol</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>