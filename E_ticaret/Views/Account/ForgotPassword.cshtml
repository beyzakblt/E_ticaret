@{
    ViewData["Title"] = "Şifremi Unuttum";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-lg rounded-4 p-4 p-md-5 animate__animated animate__fadeInUp">
                <div class="text-center mb-4">
                    @* Animasyonlu ve şık bir ikon *@
                    <div class="bg-primary-subtle rounded-circle d-inline-flex p-3 mb-3">
                        <i class="bi bi-shield-lock text-primary display-3"></i>
                    </div>
                    <h3 class="fw-bold mt-2">Şifremi Unuttum</h3>
                    <p class="text-muted small">E-posta adresinizi girin, size güvenli bir şifre sıfırlama linki gönderelim.</p>
                </div>

                @* Controller'dan gelen hata mesajı *@
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger border-0 rounded-pill small mb-4">
                        <i class="bi bi-exclamation-circle me-2"></i> @ViewBag.Error
                    </div>
                }

                @* Başarı mesajı (Simülasyon kodu veya gönderildi bilgisi) *@
                @if (TempData["Message"] != null)
                {
                    <div class="alert alert-success border-0 rounded-4 small mb-4">
                        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Message"]
                    </div>
                }

                <form asp-action="ForgotPassword" method="post">
                    <div class="mb-4">
                        <label class="form-label small fw-bold ms-2">E-posta Adresiniz</label>
                        <input type="email" name="email" class="form-control rounded-pill px-4 py-3 border-2"
                               placeholder="ornek@mail.com" required>
                    </div>
                    
                    <button type="submit" class="gradient-btn w-100 border-0 shadow-lg py-3 fw-bold">
                        Sıfırlama Linki Gönder
                    </button>
                    
                    <div class="text-center mt-4">
                        <a href="/Account/Login" class="text-decoration-none small fw-bold text-primary">
                            <i class="bi bi-arrow-left me-1"></i> Giriş Ekranına Dön
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    /* Tasarımın diğer sayfalarla uyumlu olması için gerekli CSS */
    .border-2 {
        border-width: 2px !important;
    }
    
    .gradient-btn {
        background: linear-gradient(135deg, #FF3CAC, #784BA0);
        color: white;
        border-radius: 50px;
        transition: 0.3s;
        font-weight: 600;
    }

        .gradient-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(120, 75, 160, 0.3);
            color: white;
        }

    .form-control:focus {
        border-color: #784BA0;
        box-shadow: none;
    }
</style>