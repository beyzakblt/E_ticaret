@{
    ViewData["Title"] = "Yeni Şifre Belirle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5 mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-lg rounded-4 p-4 p-md-5 animate__animated animate__fadeIn">
                <div class="text-center mb-4">
                    <div class="bg-primary-subtle rounded-circle d-inline-flex p-3 mb-3">
                        <i class="bi bi-shield-lock-fill text-primary fs-1"></i>
                    </div>
                    <h3 class="fw-bold">Yeni Şifre Belirle</h3>
                    <p class="text-muted small">Lütfen hesabınız için yeni ve güçlü bir şifre oluşturun.</p>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger border-0 rounded-pill small">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.Error
                    </div>
                }

                <form asp-action="ResetPassword" method="post" id="resetForm">
                    @* Controller'dan gelen güvenlik anahtarını (token) gizli olarak gönderiyoruz *@
                    <input type="hidden" name="token" value="@ViewBag.Token" />

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Yeni Şifre</label>
                        <input type="password" name="newPassword" id="pass1"
                               class="form-control rounded-pill px-4 py-3 border-2"
                               placeholder="********" required>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold">Şifre Tekrar</label>
                        <input type="password" id="pass2"
                               class="form-control rounded-pill px-4 py-3 border-2"
                               placeholder="********" required>
                        <div id="msg" class="small mt-2"></div>
                    </div>

                    <button type="submit" class="gradient-btn w-100 border-0 shadow-lg py-3 fw-bold">
                        Şifremi Güncelle
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // İki şifrenin uyuşup uyuşmadığını kontrol eden minik bir JS
        $('#resetForm').on('submit', function (e) {
            var p1 = $('#pass1').val();
            var p2 = $('#pass2').val();

            if (p1 !== p2) {
                $('#msg').text("Şifreler birbiriyle eşleşmiyor!").addClass("text-danger");
                e.preventDefault();
                return false;
            }
        });
    </script>
}

<style>
    .border-2 {

        border-width: 2px !important;
    }
    .gradient-btn {
        background: linear-gradient(135deg, #FF3CAC, #784BA0);
        color: white;
        border-radius: 50px;
        transition: 0.3s;
    }

        .gradient-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(120, 75, 160, 0.3);
            color: white;
        }
</style>