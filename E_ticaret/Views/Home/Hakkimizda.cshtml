@{
    ViewData["Title"] = "Hakkımızda";
}

@* Üst Kısım: Standart Mavi yerine senin Gradyanın *@
<div class="py-5 mb-5 rounded-bottom-5 shadow-sm text-white" style="background: var(--main-gradient);">
    <div class="container text-center py-4 animate__animated animate__fadeIn">
        <h1 class="display-4 fw-bold">Biz Kimiz?</h1>
        <p class="lead opacity-75">Geleceğin alışveriş deneyimini bugünden tasarlıyoruz.</p>
    </div>
</div>

<div class="container pb-5">
    <div class="row align-items-center g-5 mb-5">
        <div class="col-lg-6 animate__animated animate__fadeInLeft">
            <div class="position-relative">
                @* Görseli daha butik/moda odaklı bir şeyle değiştirebilirsin *@
                <img src="https://images.unsplash.com/photo-1441986300917-64674bd600d8?auto=format&fit=crop&q=80&w=1000" class="img-fluid rounded-5 shadow-lg" alt="Hakkımızda">
                <div class="position-absolute bottom-0 start-0 translate-middle-y bg-white p-4 shadow rounded-4 ms-4 d-none d-md-block border-start border-primary border-4">
                    <h3 class="fw-bold text-primary mb-0">2026</h3>
                    <p class="text-muted small mb-0">Kuruluş Yılımız</p>
                </div>
            </div>
        </div>

        <div class="col-lg-6 animate__animated animate__fadeInRight">
            <h2 class="fw-bold mb-4">Hikayemiz</h2>
            <p class="text-muted fs-5 lh-lg">
                <strong>Beyza Store</strong>, kullanıcı dostu arayüzü ve güvenilir altyapısı ile dijital dünyada fark yaratmak amacıyla kuruldu.
                Sadece bir alışveriş sitesi değil, aynı zamanda teknoloji ve tasarımın buluştuğu bir platform olmayı hedefliyoruz.
            </p>
            <p class="text-muted fs-5 lh-lg">
                Yazılım geliştirme tutkusuyla çıktığımız bu yolda, her bir satır kodu sizlerin en güvenli ve en hızlı alışveriş deneyimini
                yaşamanız için özenle yazdık.
            </p>

            <div class="row g-4 mt-2">
                <div class="col-6">
                    <div class="d-flex align-items-center gap-3">
                        <i class="bi bi-check-circle-fill text-primary fs-3"></i>
                        <span class="fw-bold text-dark">Güvenli Ödeme</span>
                    </div>
                </div>
                <div class="col-6">
                    <div class="d-flex align-items-center gap-3">
                        <i class="bi bi-check-circle-fill text-primary fs-3"></i>
                        <span class="fw-bold text-dark">Hızlı Teslimat</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @* Kartlar: Arka planı biraz daha şıklaştıralım *@
    <div class="row g-4 text-center mt-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100 bg-white border-bottom border-primary border-4">
                <i class="bi bi-laptop fs-1 text-primary mb-3"></i>
                <h4 class="fw-bold">Modern Teknoloji</h4>
                <p class="text-muted small">ASP.NET Core ve en güncel yazılım mimarileriyle hazırlanan sağlam bir altyapı.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100 bg-white border-bottom border-danger border-4">
                <i class="bi bi-heart-fill fs-1 text-danger mb-3"></i>
                <h4 class="fw-bold">Müşteri Odaklılık</h4>
                <p class="text-muted small">Sizlerin memnuniyeti bizim için her zaman en büyük motivasyon kaynağıdır.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100 bg-white border-bottom border-success border-4">
                <i class="bi bi-shield-lock-fill fs-1 text-success mb-3"></i>
                <h4 class="fw-bold">Yüksek Güvenlik</h4>
                <p class="text-muted small">Verileriniz ve ödemeleriniz en üst düzey güvenlik protokolleriyle korunur.</p>
            </div>
        </div>
    </div>
</div>