@{
    ViewData["Title"] = "Sıkça Sorulan Sorular";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="text-center mb-5 animate__animated animate__fadeIn">
        <h2 class="fw-bold">Sıkça Sorulan Sorular</h2>
        <p class="text-muted">Merak ettiğiniz tüm soruların cevaplarını burada bulabilirsiniz.</p>
    </div>

    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="accordion accordion-flush shadow-sm rounded-4 overflow-hidden" id="faqAccordion">
                
                @* SORU 1 *@
                <div class="accordion-item border-0">
                    <h2 class="accordion-header">
                        <button class="accordion-button fw-bold py-4" type="button" data-bs-toggle="collapse" data-bs-target="#q1">
                            <i class="bi bi-truck me-2 text-primary"></i> Kargo süreci nasıl işliyor?
                        </button>
                    </h2>
                    <div id="q1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                        <div class="accordion-body text-muted">
                            Siparişleriniz onaylandıktan sonra 24 saat içerisinde kargoya teslim edilir. Kargo takip numaranız size SMS ve e-posta yoluyla iletilecektir.
                        </div>
                    </div>
                </div>

                @* SORU 2 *@
                <div class="accordion-item border-top">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed fw-bold py-4" type="button" data-bs-toggle="collapse" data-bs-target="#q2">
                            <i class="bi bi-arrow-left-right me-2 text-primary"></i> İade ve değişim yapabilir miyim?
                        </button>
                    </h2>
                    <div id="q2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body text-muted">
                            Evet, teslim aldığınız ürünü 14 gün içerisinde orijinal ambalajı bozulmadan iade edebilirsiniz. "Siparişlerim" sayfasından iade talebi oluşturmanız yeterlidir.
                        </div>
                    </div>
                </div>

                @* SORU 3 *@
                <div class="accordion-item border-top">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed fw-bold py-4" type="button" data-bs-toggle="collapse" data-bs-target="#q3">
                            <i class="bi bi-shield-lock me-2 text-primary"></i> Ödeme yöntemleriniz güvenli mi?
                        </button>
                    </h2>
                    <div id="q3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body text-muted">
                            Tüm ödeme işlemleriniz 256-bit SSL sertifikası ile korunmaktadır. Kredi kartı bilgileriniz sistemimizde asla saklanmaz.
                        </div>
                    </div>
                </div>

                @* SORU 4 *@
                <div class="accordion-item border-top">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed fw-bold py-4" type="button" data-bs-toggle="collapse" data-bs-target="#q4">
                            <i class="bi bi-person-check me-2 text-primary"></i> Üye olmadan sipariş verebilir miyim?
                        </button>
                    </h2>
                    <div id="q4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                        <div class="accordion-body text-muted">
                            Evet, "Misafir Olarak Devam Et" seçeneği ile üye olmadan hızlıca siparişinizi tamamlayabilirsiniz.
                        </div>
                    </div>
                </div>

            </div>

            <div class="text-center mt-5">
                <p class="text-muted">Başka bir sorunuz mu var?</p>
                <a href="/Home/Contact" class="btn btn-outline-primary rounded-pill px-4">Bize Ulaşın</a>
            </div>
        </div>
    </div>
</div>

<style>
    .accordion-button:not(.collapsed) {
        background-color: #f8f9ff;
        color: #784BA0;
        box-shadow: none;
    }

    .accordion-button:focus {
        box-shadow: none;
        border-color: rgba(0,0,0,.125);
    }

    .accordion-item:last-child {
        border-bottom-left-radius: 20px;
        border-bottom-right-radius: 20px;
    }

    .accordion-item:first-child {
        border-top-left-radius: 20px;
        border-top-right-radius: 20px;
    }
</style>