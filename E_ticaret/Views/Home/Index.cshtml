@model IEnumerable<E_ticaret.Models.Urunler>
@inject EticaretContext _db
@{
    ViewData["Title"] = "Anasayfa";
    var userId = Context.Session.GetString("UserId");
}

<div class="container py-5">
    <h2 class="fw-bold mb-4">Ürünlerimiz</h2>
    <div class="row g-4">
        @foreach (var item in Model)
        {
            // Bu ürünün o an kullanıcının sepetinde kaç adet olduğunu bulalım
            int sepetAdet = 0;
            if (userId != null)
            {
                sepetAdet = _db.Siparislers.FirstOrDefault(x => x.KullaniciId == int.Parse(userId) && x.UrunId == item.Id && x.Durum == "Sepette")?.Adet ?? 0;
            }

            <div class="col-md-3">
                <div class="card h-100 p-3 shadow-sm border-0 rounded-4">
                    <img src="https://picsum.photos/400/500?product=@item.Id" class="card-img-top rounded-4 mb-3" alt="@item.UrunAdi">
                    <div class="card-body p-0">
                        <h5 class="fw-bold">@item.UrunAdi</h5>
                        <p class="text-muted small">@item.Aciklama</p>

                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="fs-5 fw-bold text-primary">@item.Fiyat.ToString("C2")</span>

                            @* ARTI - EKSİ BUTONLARI *@
                            <div class="d-flex align-items-center bg-light rounded-pill p-1">
                                <button class="btn btn-sm btn-white rounded-circle shadow-sm" onclick="sepetGuncelle(@item.Id, -1)">
                                    <i class="bi bi-dash"></i>
                                </button>

                                <span id="adet-@item.Id" class="mx-2 fw-bold">@sepetAdet</span>

                                <button class="btn btn-sm btn-primary rounded-circle shadow-sm" onclick="sepetGuncelle(@item.Id, 1)">
                                    <i class="bi bi-plus"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        function sepetGuncelle(urunId, degisim) {
            $.post("/Cart/UpdateQuantity", { id: urunId, change: degisim }, function (response) {
                if (response.success) {
                    // 1. Karttaki yerel adet sayısını güncelle
                    $("#adet-" + urunId).text(response.yeniUrunAdet);

                    // 2. Navbardaki toplam sepet sayısını güncelle
                    $("#cartCount").text(response.toplamSepetSayisi);

                    // Efekt verelim
                    $("#cartCount").fadeOut(100).fadeIn(100);
                } else {
                    window.location.href = "/Account/Login";
                }
            });
        }
    </script>
}