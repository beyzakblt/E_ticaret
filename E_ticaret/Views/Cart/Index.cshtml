@model IEnumerable<E_ticaret.Models.Siparisler>
@inject EticaretContext _db
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    decimal? genelToplam = Model.Sum(x => x.ToplamFiyat ?? 0);
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg rounded-4 p-4">
                <h3 class="fw-bold mb-4"><i class="bi bi-cart3 me-2"></i>Sepetim</h3>

                @if (!Model.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-cart-x display-1 text-muted"></i>
                        <p class="mt-3 fs-5">Sepetinizde ürün bulunmuyor.</p>
                        <a href="/" class="gradient-btn px-4 py-2 text-decoration-none">Hemen Alışverişe Başla</a>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Ürün</th>
                                    <th>Fiyat</th>
                                    <th class="text-center">Adet</th>
                                    <th>Toplam</th>
                                    <th>İşlem</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    var urun = _db.Urunlers.FirstOrDefault(u => u.Id == item.UrunId);
                                    <tr id="row-@item.UrunId">
                                        @* ID olarak UrunId kullanıyoruz ki script ile kolay bulalım *@
                                        <td>
                                            <div class="fw-bold">@(urun?.UrunAdi ?? "Ürün Bilgisi Yok")</div>
                                            <div class="small text-muted">@(urun?.Aciklama ?? "")</div>
                                        </td>
                                        <td>@urun?.Fiyat.ToString("C2")</td>
                                        <td class="text-center">
                                            @* ARTI EKSİ BUTONLARI *@
                                            <div class="d-flex align-items-center justify-content-center bg-light rounded-pill p-1" style="width: fit-content; margin: auto;">
                                                <button class="btn btn-sm btn-white rounded-circle shadow-sm" onclick="sepetGuncelle(@item.UrunId, -1)">
                                                    <i class="bi bi-dash"></i>
                                                </button>

                                                <span id="adet-@item.UrunId" class="mx-3 fw-bold">@item.Adet</span>

                                                <button class="btn btn-sm btn-primary rounded-circle shadow-sm" onclick="sepetGuncelle(@item.UrunId, 1)">
                                                    <i class="bi bi-plus"></i>
                                                </button>
                                            </div>
                                        </td>
                                        <td class="fw-bold text-primary" id="toplam-@item.UrunId">
                                            @item.ToplamFiyat?.ToString("C2")
                                        </td>
                                        <td>
                                            <button onclick="sepettenSil(@item.Id)" class="btn btn-link text-danger p-0 border-0">
                                                <i class="bi bi-trash fs-5"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-lg rounded-4 p-4 bg-light">
                <h4 class="fw-bold mb-4">Sipariş Özeti</h4>
                <div class="d-flex justify-content-between mb-2">
                    <span>Ara Toplam</span>
                    <span class="fw-bold" id="araToplam">@genelToplam?.ToString("C2")</span>
                </div>
                <hr>
                <div class="d-flex justify-content-between mb-4">
                    <span class="fw-bold fs-5">Genel Toplam</span>
                    <span class="fw-bold fs-5 text-primary" id="genelToplam">@genelToplam?.ToString("C2")</span>
                </div>
                <a href="/Cart/Checkout" class="gradient-btn w-100 py-3 shadow border-0 text-center text-decoration-none">Alışverişi Tamamla</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        // Ürün Adedi Güncelleme (Artı/Eksi)
        function sepetGuncelle(urunId, degisim) {
            $.post("/Cart/UpdateQuantity", { id: urunId, change: degisim }, function (response) {
                if (response.success) {
                    if (response.yeniUrunAdet <= 0) {
                        location.reload(); // Ürün bittiyse satırı kaldırmak için yenile
                    } else {
                        // Sayfayı yenilemeden verileri güncelle
                        $("#adet-" + urunId).text(response.yeniUrunAdet);
                        $("#cartCount").text(response.toplamSepetSayisi); // Navbardaki sayı
                        location.reload(); // Fiyat hesaplamaları için en garantisi şu anlık bu
                    }
                }
            });
        }

        // Tamamen Silme
               function sepettenSil(siparisId) {
            if (confirm("Bu ürünü sepetten çıkarmak istediğinize emin misiniz?")) {
                // Buradaki "id" ismi, Controller'daki parametre ismiyle (int id) aynı olmalı
                $.post("/Cart/RemoveFromCart", { id: siparisId }, function (data) {
                    if (data.success) {
                        // Silme başarılıysa satırı anında gizle veya sayfayı yenile
                        location.reload();
                    } else {
                        alert("Silme işlemi başarısız oldu.");
                    }
                }).fail(function() {
                    alert("Sunucuya bağlanırken bir hata oluştu!");
                });
            }
        }
    </script>
}