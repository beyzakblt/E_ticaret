@using Microsoft.AspNetCore.Http
@model IEnumerable<E_ticaret.Models.Siparisler>
@inject E_ticaret.Models.EticaretContext _db
@{
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Kullanıcı Durumu Kontrolü
    var userIdString = Context.Session.GetString("UserId");
    bool isMember = !string.IsNullOrEmpty(userIdString);

    List<E_ticaret.Models.KullaniciAdresleri> adresler = new List<E_ticaret.Models.KullaniciAdresleri>();
    if (isMember)
    {
        int uId = int.Parse(userIdString);
        adresler = _db.KullaniciAdresleris.Where(x => x.KullaniciId == uId).ToList();
    }

    // Fiyat Hesaplamaları
    decimal araToplam = Model.Sum(x => x.ToplamFiyat ?? 0);
    int? indirimOrani = Context.Session.GetInt32("IndirimOrani");
    decimal indirimTutari = indirimOrani.HasValue ? (araToplam * indirimOrani.Value / 100) : 0;
    decimal genelToplam = araToplam - indirimTutari;
}

<style>
    :root {
        --main-gradient: linear-gradient(135deg, #FF3CAC 0%, #784BA0 50%, #2B86C5 100%);
        --soft-purple: #f8f9ff;
    }

    .checkout-card { border: none; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); background: #fff; }
    .address-selection-card { display: block; cursor: pointer; margin-bottom: 15px; }
    .address-box { border: 2px solid #eee !important; border-radius: 15px; transition: all 0.3s ease; position: relative; }
    .address-selection-card input:checked + .address-box { border-color: #784BA0 !important; background-color: var(--soft-purple) !important; box-shadow: 0 5px 15px rgba(120, 75, 160, 0.1); }
    .check-icon { display: none; color: #784BA0; font-size: 1.2rem; }
    .address-selection-card input:checked + .address-box .check-icon { display: block; }
    .form-control { border-radius: 50px; padding: 12px 20px; border: 1px solid #e0e0e0; }
    .form-control:focus { border-color: #784BA0; box-shadow: 0 0 0 0.25rem rgba(120, 75, 160, 0.1); }
    textarea.form-control { border-radius: 15px; }
    .gradient-btn { background: var(--main-gradient); color: white; border: none; padding: 15px; border-radius: 50px; font-weight: 700; transition: 0.3s; }
    .gradient-btn:hover { transform: translateY(-3px); box-shadow: 0 10px 20px rgba(120, 75, 160, 0.3); color: #fff; }
    .contract-link { color: #784BA0; text-decoration: none; font-weight: 600; }
    .contract-link:hover { text-decoration: underline; }
</style>

<div class="container py-5">
    <div class="row g-4">
        @* SOL TARAF: ADRES VEYA FORM *@
        <div class="col-lg-7">
            <form id="orderForm" asp-action="CompleteOrder" method="post">
                @if (isMember)
                {
                    <div class="card checkout-card p-4 mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h4 class="fw-bold mb-0"><i class="bi bi-geo-alt me-2 text-primary"></i>Adres Seçin</h4>
                            <a href="/Account/AdresEkle" class="btn btn-sm btn-outline-primary rounded-pill px-3">Yeni Adres</a>
                        </div>
                        <div class="row g-3">
                            @if (adresler.Any())
                            {
                                @foreach (var adres in adresler)
                                {
                                    <div class="col-12">
                                        <label class="address-selection-card">
                                            <input type="radio" name="SecilenAdresId" value="@adres.Id" class="d-none" @(adres.IsDefault == true ? "checked" : "") required>
                                            <span class="d-block p-3 address-box">
                                                <span class="d-flex justify-content-between align-items-center">
                                                    <span class="fw-bold">@adres.AdresBasligi</span>
                                                    <i class="bi bi-check-circle-fill check-icon"></i>
                                                </span>
                                                <span class="d-block small text-muted mt-2">@adres.AdSoyad - @adres.Telefon</span>
                                                <span class="d-block small text-dark mt-1">@adres.TamAdres @adres.Ilce / @adres.Sehir</span>
                                            </span>
                                        </label>
                                    </div>
                                }
                                <input type="hidden" id="FinalAdresId" name="AdresId" value="@(adresler.FirstOrDefault(x => x.IsDefault == true)?.Id ?? 0)" />
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="card checkout-card p-4 mb-4">
                        <h4 class="fw-bold mb-4 text-primary"><i class="bi bi-person-badge me-2"></i>Misafir Bilgileri</h4>
                        <div class="row g-3">
                            <div class="col-12"><input type="text" name="adSoyad" class="form-control" placeholder="Ad Soyad" required></div>
                            <div class="col-md-6"><input type="email" name="email" class="form-control" placeholder="E-posta" required></div>
                            <div class="col-md-6"><input type="tel" name="telefon" class="form-control" placeholder="Telefon" required></div>
                            <div class="col-12"><textarea name="adres" class="form-control" rows="3" placeholder="Teslimat Adresi" required></textarea></div>
                        </div>
                    </div>
                }

                @* ÖDEME YÖNTEMİ *@
                <div class="card checkout-card p-4 mb-4">
                    <h4 class="fw-bold mb-3"><i class="bi bi-wallet2 me-2 text-primary"></i>Ödeme Yöntemi</h4>
                    <div class="form-check p-3 border rounded-4 bg-light">
                        <input class="form-check-input ms-1" type="radio" checked>
                        <label class="form-check-label ms-2 fw-bold">Kapıda Nakit / Kredi Kartı</label>
                    </div>
                </div>

                @* YASAL ONAYLAR (CHECKLIST MADDESİ) *@
                <div class="card checkout-card p-4">
                    <h4 class="fw-bold mb-3"><i class="bi bi-shield-check me-2 text-primary"></i>Sözleşme Onayları</h4>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" id="kvkkCheck" required>
                        <label class="form-check-label small" for="kvkkCheck">
                            <a href="javascript:void(0)" class="contract-link" data-bs-toggle="modal" data-bs-target="#kvkkModal">KVKK Aydınlatma Metni</a>'ni okudum ve kabul ediyorum.
                        </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="sozlesmeCheck" required>
                        <label class="form-check-label small" for="sozlesmeCheck">
                            <a href="javascript:void(0)" class="contract-link" data-bs-toggle="modal" data-bs-target="#mesafeliModal">Mesafeli Satış Sözleşmesi</a>'ni okudum ve onaylıyorum.
                        </label>
                    </div>
                </div>
            </form>
        </div>

        @* SAĞ TARAF: ÖZET *@
        <div class="col-lg-5">
            <div class="card checkout-card p-4 sticky-top" style="top: 100px;">
                <h4 class="fw-bold mb-4">Sipariş Özeti</h4>
                <div class="mb-4">
                    @foreach (var item in Model)
                    {
                        var urun = _db.Urunlers.Find(item.UrunId);
                        <div class="d-flex justify-content-between mb-2 small">
                            <span>@item.Adet x @urun?.UrunAdi</span>
                            <span class="fw-bold">@item.ToplamFiyat?.ToString("C2")</span>
                        </div>
                    }
                </div>
                <hr class="opacity-10">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Ara Toplam</span>
                    <span class="fw-bold">@araToplam.ToString("C2")</span>
                </div>
                @if (indirimOrani.HasValue)
                {
                    <div class="d-flex justify-content-between mb-2 text-success fw-bold">
                        <span>Kupon İndirimi (%@indirimOrani)</span>
                        <span>- @indirimTutari.ToString("C2")</span>
                    </div>
                }
                <div class="d-flex justify-content-between mt-3 mb-4">
                    <span class="fs-5 fw-bold">Genel Toplam</span>
                    <span class="fs-4 fw-bold text-primary">@genelToplam.ToString("C2")</span>
                </div>
                <button type="submit" form="orderForm" class="gradient-btn w-100 shadow-lg">Siparişi Onayla</button>
            </div>
        </div>
    </div>
</div>

@* SÖZLEŞME MODALLARI *@
<div class="modal fade" id="kvkkModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable modal-lg">
        <div class="modal-content rounded-4 border-0">
            <div class="modal-header border-0 bg-light">
                <h5 class="modal-title fw-bold">KVKK Aydınlatma Metni</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                @Html.Raw(_db.Sozlesmelers.FirstOrDefault(x => x.SozlesmeTipi == 1)?.Icerik ?? "KVKK metni admin panelinden eklenmelidir.")
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="mesafeliModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable modal-lg">
        <div class="modal-content rounded-4 border-0">
            <div class="modal-header border-0 bg-light">
                <h5 class="modal-title fw-bold">Mesafeli Satış Sözleşmesi</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                @Html.Raw(_db.Sozlesmelers.FirstOrDefault(x => x.SozlesmeTipi == 2)?.Icerik ?? "Satış sözleşmesi admin panelinden eklenmelidir.")
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Sayfa yüklendiğinde seçili olan (checked) radyonun ID'sini gizli inputa yaz
        $(document).ready(function() {
            var selectedId = $('input[name="SecilenAdresId"]:checked').val();
            if(selectedId) {
                $('#FinalAdresId').val(selectedId);
            }
        });

        // Değişim olduğunda güncelle
        $('input[name="SecilenAdresId"]').change(function() {
            $('#FinalAdresId').val($(this).val());
        });

        // Form Onay Kontrolü (Aynen kalsın, bu kısım çok iyi)
        $('#orderForm').on('submit', function(e) {
            if (!$('#kvkkCheck').is(':checked') || !$('#sozlesmeCheck').is(':checked')) {
                alert("Lütfen devam etmek için yasal sözleşmeleri onaylayınız.");
                e.preventDefault();
                return false;
            }
        });
    </script>
}
