@model IEnumerable<E_ticaret.Models.Siparisler>
@{
    var kullanici = ViewBag.Kullanici as E_ticaret.Models.Kullanicilar;
    decimal? genelToplam = Model.Sum(x => x.ToplamFiyat);
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-7">
            <div class="card border-0 shadow-lg rounded-4 p-4 mb-4">
                <h4 class="fw-bold mb-4"><i class="bi bi-geo-alt me-2 text-primary"></i>Teslimat Bilgileri</h4>
                <div class="bg-light p-3 rounded-4 border">
                    <p class="mb-1"><strong>Alıcı:</strong> @kullanici?.AdSoyad</p>
                    <p class="mb-1"><strong>Telefon:</strong> @kullanici?.Telefon</p>
                    <p class="mb-0"><strong>Adres:</strong> @kullanici?.Adres @kullanici?.Ilce / @kullanici?.Sehir</p>
                </div>
                <div class="mt-3">
                    <a href="/Account/Profile" class="btn btn-sm btn-outline-secondary rounded-pill">Bilgileri Güncelle</a>
                </div>
            </div>

            <div class="card border-0 shadow-lg rounded-4 p-4">
                <h4 class="fw-bold mb-4"><i class="bi bi-wallet2 me-2 text-primary"></i>Ödeme Yöntemi</h4>
                <div class="form-check p-3 border rounded-4 bg-light">
                    <input class="form-check-input ms-1" type="radio" checked>
                    <label class="form-check-label ms-2 fw-bold">
                        Kapıda Nakit / Kredi Kartı ile Ödeme
                    </label>
                    <p class="small text-muted ms-4 mb-0">Siparişinizi teslim alırken kapıda ödeyebilirsiniz.</p>
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 p-4 sticky-top" style="top: 100px;">
                <h4 class="fw-bold mb-4">Sipariş Özeti</h4>
                @foreach (var item in Model)
                {
                    <div class="d-flex justify-content-between mb-2">
                        <span>@item.Adet x Ürün</span>
                        <span class="fw-bold">@item.ToplamFiyat?.ToString("C2")</span>
                    </div>
                }
                <hr>
                <div class="d-flex justify-content-between mb-4">
                    <span class="fs-5 fw-bold">Toplam Tutar</span>
                    <span class="fs-4 fw-bold text-primary">@genelToplam?.ToString("C2")</span>
                </div>

                <form asp-action="CompleteOrder" method="post">
                    <button type="submit" class="gradient-btn w-100 py-3 rounded-pill shadow-lg border-0 fs-5">
                        Siparişi Onayla
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>