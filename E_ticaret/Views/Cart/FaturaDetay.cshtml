@model IEnumerable<E_ticaret.Models.Siparisler>
@{
    Layout = null; // Fatura sade olmalı, admin veya kullanıcı layout'u gerekmez
}
<!DOCTYPE html>
<html>
<head>
    <title>Fatura - @ViewBag.SiparisNo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
            @@media print { .no-print { display: none; } }
            .invoice-box { padding: 30px; border: 1px solid #eee; box-shadow: 0 0 10px rgba(0, 0, 0, .15); max-width: 800px; margin: auto; }
    </style>
</head>
<body class="bg-light pt-5">
    <div class="invoice-box bg-white">
        <div class="d-flex justify-content-between mb-4">
            <div>
                <h2 class="text-primary fw-bold">BEYZA SHOP</h2>
               <p>
    <strong>Müşteri:</strong> @(ViewBag.Kullanici?.AdSoyad ?? "Bilinmeyen Müşteri") <br>
    <strong>Tarih:</strong> @ViewBag.Tarih.ToString("dd.MM.yyyy")
</p>
            </div>
            <div class="text-end">
                <h4>Fatura #@ViewBag.SiparisNo</h4>
                <button onclick="window.print()" class="btn btn-sm btn-outline-secondary no-print">Yazdır / PDF Kaydet</button>
            </div>
        </div>

        <table class="table">
            <thead>
                <tr>
                    <th>Ürün</th>
                    <th>Adet</th>
                    <th class="text-end">Birim Fiyat</th>
                    <th class="text-end">Toplam</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Urun?.UrunAdi</td>
                        <td>@item.Adet</td>
                        <td class="text-end">@item.Urun?.Fiyat.ToString("C2")</td>
                        <td class="text-end">@item.ToplamFiyat?.ToString("C2")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="3" class="text-end fw-bold">Genel Toplam:</td>
                    <td class="text-end fw-bold text-success">@Model.Sum(x => x.ToplamFiyat)?.ToString("C2")</td>
                </tr>
            </tfoot>
        </table>
        <p class="small text-muted mt-5 text-center">Bizi tercih ettiğiniz için teşekkür ederiz.</p>
    </div>
</body>
</html>