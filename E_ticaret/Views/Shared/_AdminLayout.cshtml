<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - E-Ticaret Panel</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <script src="https://cdn.tiny.cloud/1/423oefzqg09vxi03lb7e5j22ob07xsehtitfmn10kph04mjn/tinymce/8/tinymce.min.js" referrerpolicy="origin" crossorigin="anonymous"></script>

    <style>
        :root {
            --sidebar-width: 260px;
            --primary-color: #0d6efd;
            --dark-bg: #1e1e2d;
            --light-bg: #f5f8fa;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--light-bg);
            overflow-x: hidden;
        }

        /* Sidebar Tasarımı */
        #sidebar {
            min-width: var(--sidebar-width);
            max-width: var(--sidebar-width);
            min-height: 100vh;
            background: var(--dark-bg);
            color: #a2a3b7;
            transition: all 0.3s;
            position: fixed;
            z-index: 1000;
        }

            #sidebar .sidebar-header {
                padding: 25px;
                background: #1b1b28;
                text-align: center;
                color: #fff;
                font-weight: 600;
                letter-spacing: 1px;
            }

            #sidebar ul {
                padding: 15px 0;
            }

                #sidebar ul li a {
                    padding: 12px 25px;
                    display: flex;
                    align-items: center;
                    color: #a2a3b7;
                    text-decoration: none;
                    transition: 0.3s;
                    font-size: 0.95rem;
                }

                    #sidebar ul li a i {
                        font-size: 1.2rem;
                        margin-right: 15px;
                    }

                    #sidebar ul li a:hover, #sidebar ul li.active > a {
                        color: #fff;
                        background: #2b2b40;
                    }

                #sidebar ul li.active > a {
                    border-left: 4px solid var(--primary-color);
                    background: #2b2b40;
                }

        /* Ana İçerik Alanı */
        .main-wrapper {
            margin-left: var(--sidebar-width);
            width: calc(100% - var(--sidebar-width));
            transition: all 0.3s;
        }

        .top-navbar {
            background: #fff;
            padding: 15px 30px;
            border-bottom: 1px solid #ebedf3;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 999;
        }

        .content-body {
            padding: 30px;
        }

        /* Kart ve Tablo Stilize */
        .card {
            border: none;
            box-shadow: 0 0 20px 0 rgba(76, 87, 125, 0.02);
            border-radius: 12px;
        }

        /* Mobil Görünüm */
        @@media (max-width: 992px) {
            #sidebar {
                margin-left: calc(-1 * var(--sidebar-width));
            }

                #sidebar.active {
                    margin-left: 0;
                }

            .main-wrapper {
                margin-left: 0;
                width: 100%;
            }
        }
    </style>
</head>
<body>

    <nav id="sidebar">
        <div class="sidebar-header">
            <i class="bi bi-cart4 me-2"></i> ETİCARET
        </div>
        <ul class="list-unstyled">
            <li class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
                <a asp-controller="Admin" asp-action="Index"><i class="bi bi-grid-1x2"></i> Dashboard</a>
            </li>

            <hr class="mx-3 opacity-25">

            <li class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Urunler" ? "active" : "")">
                <a asp-controller="Admin" asp-action="Urunler"><i class="bi bi-box-seam"></i> Ürün Yönetimi</a>
            </li>
            <li class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Kategoriler" ? "active" : "")">
                <a asp-controller="Admin" asp-action="Kategoriler"><i class="bi bi-list-ul"></i> Kategoriler</a>
            </li>
            <li class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Siparis_Yonetimi" ? "active" : "")">
                <a asp-controller="Admin" asp-action="Siparis_Yonetimi"><i class="bi bi-receipt"></i> Sipariş Yönetimi</a>
            </li>

            <hr class="mx-3 opacity-25">

            <li class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Kullanicilar" ? "active" : "")">
                <a asp-controller="Admin" asp-action="Kullanicilar"><i class="bi bi-people"></i> Kullanıcılar</a>
            </li>
            <li class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Kullanicilar" ? "active" : "")">
                <a asp-controller="Admin" asp-action="Yoneticiler"><i class="bi bi-people"></i> Yöneticiler</a>
            </li>
            <li class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "MailGonder" ? "active" : "")">
                <a asp-controller="Admin" asp-action="MailGonder"><i class="bi bi-envelope-paper-heart"></i> Toplu Mail Gönder</a>
            </li>
            <li class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "GelenKutusu" ? "active" : "")">
                <a asp-controller="Admin" asp-action="GelenKutusu"><i class="bi bi-chat-left-dots"></i> İletişim Mesajları</a>
            </li>
            <li class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Kuponlar" ? "active" : "")">
                <a asp-controller="Admin" asp-action="Kuponlar">
                    <i class="bi bi-ticket-detailed"></i> Kupon Yönetimi
                </a>
            </li>

            <hr class="mx-3 opacity-25">

            <li class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Slider" ? "active" : "")">
                <a asp-controller="Admin" asp-action="Slider"><i class="bi bi-images"></i> Slider Yönetimi</a>
            </li>
            <li class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Site_Ayarlari" ? "active" : "")">
                <a asp-controller="Admin" asp-action="Site_Ayarlari"><i class="bi bi-gear"></i> Site Ayarları</a>
            </li>
            <li class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Api_Ayarlari" ? "active" : "")">
                <a asp-controller="Admin" asp-action="Api_Ayarlari"><i class="bi bi-shield-lock"></i> Api Ayarları</a>
            </li>
            <li class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Sozlesmeler" ? "active" : "")">
                <a asp-controller="Admin" asp-action="Sozlesmeler"><i class="bi bi-file-earmark-text"></i> Sözleşmeler</a>
            </li>

            <hr class="mx-3 opacity-25">

            <li><a href="/" class="text-info"><i class="bi bi-arrow-left-circle"></i> Siteye Dön</a></li>
        </ul>
    </nav>

    <div class="main-wrapper">
        <header class="top-navbar">
            <button type="button" id="sidebarToggle" class="btn btn-light border d-lg-none">
                <i class="bi bi-list"></i>
            </button>
            <h5 class="mb-0 d-none d-md-block">Admin Yönetim Paneli</h5>

            <div class="dropdown">
                <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle text-dark" data-bs-toggle="dropdown">
                    <img src="https://ui-avatars.com/api/?name=Admin&background=0D6EFD&color=fff" width="35" height="35" class="rounded-circle me-2">
                    <span class="fw-semibold">Beyza Admin</span>
                </a>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                    <li><a class="dropdown-item" href="#"><i class="bi bi-person me-2"></i> Profilim</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item text-danger" asp-controller="Admin" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i> Çıkış Yap</a></li>
                </ul>
            </div>
        </header>

        <main class="content-body">
            @RenderBody()
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('sidebarToggle').addEventListener('click', function() {
            document.getElementById('sidebar').classList.toggle('active');
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>