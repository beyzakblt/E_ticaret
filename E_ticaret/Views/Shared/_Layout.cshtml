@using E_ticaret.Models
@using Microsoft.AspNetCore.Http
@inject EticaretContext _context
@{
    var ayar = _context.SiteAyarlaris.FirstOrDefault();
    var userName = Context.Session.GetString("UserName");
    var userIdString = Context.Session.GetString("UserId");
    var guestId = Context.Session.GetString("GuestId");

    int sepetAdet = 0;
    int favoriAdet = 0;

    int uId = 0;
    bool isMember = !string.IsNullOrEmpty(userIdString) && int.TryParse(userIdString, out uId);
    
    // Sepet Sayısını Getir
    sepetAdet = _context.Siparislers
        .Where(x => (isMember ? x.KullaniciId == uId : x.GuestId == guestId) && x.Durum == "Sepette")
        .Sum(x => (int?)x.Adet) ?? 0;

    if (isMember)
    {
        favoriAdet = _context.Favorilers.Count(x => x.KullaniciId == uId);
    }
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ayar?.SiteAdi ?? "BEYZA STORE")</title>

    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.css"/>
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick-theme.css"/>

    <style>
        :root {
            --main-gradient: linear-gradient(135deg, #FF3CAC 0%, #784BA0 50%, #2B86C5 100%);
            --glass: rgba(255, 255, 255, 0.95);
        }

        html, body { height: 100%; }
        body { font-family: 'Outfit', sans-serif; background: #fdfdfd; display: flex; flex-direction: column; }
        main { flex: 1 0 auto; }
        
        .navbar-custom { 
            background: var(--glass); 
            backdrop-filter: blur(15px); 
            border-bottom: 1px solid rgba(0,0,0,0.05); 
            padding: 0.8rem 0; 
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.05);
            z-index: 1050 !important; 
        }

        .dropdown-menu { 
            z-index: 2000 !important; 
            border-radius: 15px;
            border: none;
            box-shadow: 0 10px 40px rgba(0,0,0,0.1) !important;
        }

        .logo-text-wrapper { display: flex; align-items: center; gap: 10px; text-decoration: none; }
        .logo-icon { background: var(--main-gradient); color: white; width: 38px; height: 38px; display: flex; align-items: center; justify-content: center; border-radius: 10px; font-size: 1.1rem; }
        .logo-name { font-weight: 800; letter-spacing: -1px; font-size: 1.5rem; background: var(--main-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; text-transform: uppercase; }
        
        .whatsapp-chat { position: fixed; bottom: 30px; left: 30px; z-index: 9999; background: #25d366; color: white; width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 30px; box-shadow: 0 10px 25px rgba(37, 211, 102, 0.4); transition: 0.3s; text-decoration: none; }
        .whatsapp-chat:hover { transform: scale(1.1) rotate(5deg); color: white; }
        
        .nav-icon-badge { font-size: 0.65rem; padding: 0.35em 0.5em; border: 2px solid white; top: 5px !important; }
        .gradient-btn { background: var(--main-gradient); color: white; border: none; padding: 10px 25px; border-radius: 50px; font-weight: 600; transition: 0.3s; text-decoration: none; display: inline-block; }
        .gradient-btn:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(120, 75, 160, 0.3); color: white; }

        footer { flex-shrink: 0; background: #0b1120; color: rgba(255,255,255,0.7); padding: 60px 0 30px; margin-top: 50px; }
        .footer-link { color: rgba(255,255,255,0.6); text-decoration: none; transition: 0.3s; font-size: 0.9rem; }
        .footer-link:hover { color: #fff; }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-custom sticky-top">
        <div class="container">
            <a class="navbar-brand p-0" href="/">
                <div class="logo-text-wrapper">
                    <span class="logo-icon"><i class="bi bi-bag-heart-fill"></i></span>
                    <span class="logo-name">@(ayar?.SiteAdi ?? "BEYZA STORE")</span>
                </div>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <div class="ms-auto d-flex align-items-center gap-2 mt-3 mt-lg-0">
                    <form action="/Home/Index" method="get" class="me-lg-3" style="max-width: 200px;">
                        <div class="input-group bg-light rounded-pill p-1 shadow-sm border">
                            <input type="text" name="q" class="form-control border-0 bg-transparent ps-3" placeholder="Ara..." value="@ViewBag.SearchQuery">
                            <button class="btn btn-white rounded-circle" type="submit"><i class="bi bi-search text-primary"></i></button>
                        </div>
                    </form>

                    <a href="/Home/Index" class="btn btn-link text-dark text-decoration-none fw-semibold small">Ürünler</a>
                    @* SİPARİŞ TAKİBİ BUTONU *@
                    <a href="/Home/SiparisTakip" class="btn btn-link text-dark text-decoration-none fw-semibold small">
                        <i class="bi bi-truck me-1"></i> Takip Et
                    </a>
                    <a href="/Home/SSS" class="btn btn-link text-dark text-decoration-none fw-semibold small">SSS</a>
                    <a href="/Home/Contact" class="btn btn-link text-dark text-decoration-none fw-semibold small">İletişim</a>

                    <a href="/Cart/Index" class="btn btn-link text-dark px-2 position-relative">
                        <i class="bi bi-cart3 fs-5"></i>
                        @if (sepetAdet > 0)
                        {
                            <span class="position-absolute translate-middle badge rounded-pill bg-danger nav-icon-badge">@sepetAdet</span>
                        }
                    </a>

                    @if (isMember)
                    {
                        <a href="/Home/Favorilerim" class="btn btn-link text-dark px-2 position-relative">
                            <i class="bi bi-heart-fill text-danger fs-5"></i>
                            @if (favoriAdet > 0)
                            {
                                <span class="position-absolute translate-middle badge rounded-pill bg-dark nav-icon-badge">@favoriAdet</span>
                            }
                        </a>
                        <div class="dropdown ms-2">
                            <button class="btn btn-light rounded-pill dropdown-toggle fw-bold shadow-sm" type="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1 text-primary"></i> @userName
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-2">
                                <li><a class="dropdown-item py-2" href="/Account/Profile"><i class="bi bi-person-gear me-2 text-primary"></i>Profilim</a></li>
                                <li><a class="dropdown-item py-2" href="/Account/Orders"><i class="bi bi-bag-check me-2 text-success"></i>Siparişlerim</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item py-2 text-danger" href="/Account/Logout"><i class="bi bi-box-arrow-right me-2"></i>Çıkış Yap</a></li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a href="/Account/Login" class="gradient-btn shadow-sm ms-2">Giriş Yap</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    @if (!string.IsNullOrEmpty(ayar?.Whatsapp))
    {
        <a href="https://wa.me/@ayar.Whatsapp" class="whatsapp-chat shadow-lg" target="_blank">
            <i class="bi bi-whatsapp"></i>
        </a>
    }

    <main role="main">
        @RenderBody()
    </main>

    <footer>
        <div class="container text-center">
            <h4 class="text-white fw-bold mb-3">@ayar?.SiteAdi</h4>
            <div class="mb-4">
                <a href="/Home/Hakkimizda" class="footer-link mx-2">Hakkımızda</a>
                <span class="text-muted">|</span>
                <a href="/Home/SiparisTakip" class="footer-link mx-2 text-info fw-bold">Sipariş Takibi</a>
                <span class="text-muted">|</span>
                <a href="/Home/SSS" class="footer-link mx-2">Sıkça Sorulan Sorular</a>
                <span class="text-muted">|</span>
                <a href="/Home/Contact" class="footer-link mx-2">İletişim</a>
            </div>

            @if (!string.IsNullOrEmpty(ayar?.Tel))
            {
                <div class="mb-4">
                    <p class="mb-1 text-white opacity-50 small">Müşteri Hizmetleri</p>
                    <a href="tel:@ayar.Tel" class="fs-5 fw-bold text-white text-decoration-none">
                        <i class="bi bi-telephone-fill me-2 text-primary"></i> @ayar.Tel
                    </a>
                </div>
            }

            <div class="social-links mb-4">
                @if (!string.IsNullOrEmpty(ayar?.Instagram)) { <a href="@ayar.Instagram" class="mx-2 text-white fs-4"><i class="bi bi-instagram"></i></a> }
                @if (!string.IsNullOrEmpty(ayar?.Facebook)) { <a href="@ayar.Facebook" class="mx-2 text-white fs-4"><i class="bi bi-facebook"></i></a> }
            </div>
            <p class="small opacity-25">&copy; 2026 @ayar?.SiteAdi. Tüm Hakları Saklıdır.</p>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js"></script>

    <script type="text/javascript">
        var Tawk_API=Tawk_API||{}, Tawk_LoadStart=new Date();
        (function(){
            var s1=document.createElement("script"),s0=document.getElementsByTagName("script")[0];
            s1.async=true; s1.src='https://embed.tawk.to/69aec00f7ac1721c39912d24/default';
            s1.charset='UTF-8'; s1.setAttribute('crossorigin','*'); s0.parentNode.insertBefore(s1,s0);
        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>