@model IEnumerable<E_ticaret.Models.ContactMessage>
@{
    ViewData["Title"] = "İletişim Mesajları";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header bg-white py-3 border-0">
            <h5 class="fw-bold mb-0 text-primary"><i class="bi bi-chat-left-text-fill me-2"></i>Gelen Mesajlar</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4">Durum</th>
                            <th>Gönderen</th>
                            <th>Konu</th>
                            <th>Tarih</th>
                            <th class="text-end pe-4">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr id="row-@item.Id" class="@(item.IsRead ? "opacity-75" : "fw-bold")">
                                <td class="ps-4">
                                    @if (!item.IsRead)
                                    {
                                        <span class="badge rounded-pill bg-danger">Yeni</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-secondary">Okundu</span>
                                    }
                                </td>
                                <td>
                                    <div>@item.FullName</div>
                                    <small class="text-muted">@item.Email</small>
                                </td>
                                <td>@item.Subject</td>
                                <td class="small text-muted">@item.CreatedAt.ToString("g")</td>
                                <td class="text-end pe-4">
                                    <button class="btn btn-sm btn-outline-primary rounded-pill" onclick="mesajDetay(@item.Id, '@item.FullName', '@item.Email', '@item.Message')">
                                        <i class="bi bi-eye"></i> Oku
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="mesajModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4 shadow">
            <div class="modal-header border-0 pb-0">
                <h5 class="fw-bold">Mesaj Detayı</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p><strong>Kimden:</strong> <span id="m_ad"></span> (<span id="m_mail"></span>)</p>
                <hr class="opacity-25">
                <p id="m_mesaj" class="text-muted lh-lg"></p>
            </div>
            <div class="modal-footer border-0 pt-0">
                <a href="#" id="cevaplaBtn" class="btn btn-primary rounded-pill px-4">Cevapla</a>
                <button type="button" class="btn btn-light rounded-pill" data-bs-dismiss="modal">Kapat</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function mesajDetay(id, ad, mail, mesaj) {
            $("#m_ad").text(ad);
            $("#m_mail").text(mail);
            $("#m_mesaj").text(mesaj);

            // Cevapla butonu MailGonder sayfasına e-posta parametresiyle gitsin
            $("#cevaplaBtn").attr("href", "/Admin/MailGonder?targetEmail=" + mail);

            // Modal'ı aç
            var myModal = new bootstrap.Modal(document.getElementById('mesajModal'));
            myModal.show();

            // Okundu olarak işaretle (Arka planda)
            $.post("/Admin/MesajOkunduYap", { id: id }, function (res) {
                if(res.success) {
                    $("#row-" + id).removeClass("fw-bold").addClass("opacity-75");
                }
            });
        }
    </script>
}