@model IEnumerable<E_ticaret.Models.Siparisler>
@inject EticaretContext _db
@{
    ViewData["Title"] = "Sipariş Yönetimi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-header bg-white py-3 border-0">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-receipt me-2 text-primary"></i> Sipariş Yönetimi</h5>
            <span class="badge bg-primary rounded-pill px-3">Toplam @Model.Count() Sipariş</span>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4">Sipariş No & Tarih</th>
                        <th>Müşteri / İletişim</th>
                        <th>Ürün Bilgisi</th>
                        <th>Tutar</th>
                        <th>Durum</th>
                        <th class="text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var kullanici = _db.Kullanicilars.FirstOrDefault(k => k.Id == item.KullaniciId);
                        var urun = _db.Urunlers.FirstOrDefault(u => u.Id == item.UrunId);

                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold text-dark">#@item.Id</div>
                                <small class="text-muted">@item.SiparisTarihi?.ToString("dd.MM.yyyy HH:mm")</small>
                            </td>
                            <td>
                                <div class="fw-semibold text-dark">@(kullanici?.AdSoyad ?? "Bilinmeyen")</div>
                                <div class="small text-muted text-truncate" style="max-width: 180px;" title="@kullanici?.Adres">
                                    <i class="bi bi-geo-alt me-1"></i> @(kullanici?.Sehir) / @(kullanici?.Ilce)
                                </div>
                            </td>
                            <td>
                                <div class="fw-bold text-dark">@(urun?.UrunAdi ?? "Silinmiş Ürün")</div>
                                <small class="text-muted">Adet: @item.Adet</small>
                            </td>
                            <td class="fw-bold text-primary">@item.ToplamFiyat?.ToString("C2")</td>
                            <td>
                                @{
                                    var badgeClass = item.Durum switch
                                    {
                                        "Sipariş Alındı" => "bg-info text-dark",
                                        "Hazırlanıyor" => "bg-warning text-dark",
                                        "Kargoya Verildi" => "bg-primary text-white",
                                        "Teslim Edildi" => "bg-success text-white",
                                        "İptal Edildi" => "bg-danger text-white",
                                        // BURAYI GÜNCELLEDİK: AccountController ile tam uyumlu hale getirdik
                                        "İade Talebi Oluşturuldu" => "bg-dark text-white",
                                        "İade Onaylandı" => "bg-success text-white",
                                        "İade Reddedildi" => "bg-secondary text-white",
                                        _ => "bg-secondary text-white"
                                    };
                                }
                                <span class="badge @badgeClass rounded-pill px-3 shadow-sm">@item.Durum</span>

                                @* İade Nedeni ve Onay Butonları *@
                                @if (item.Durum == "İade Talebi Oluşturuldu")
                                {
                                    <div class="mt-2 small p-2 bg-light rounded-3 border border-warning shadow-sm animate__animated animate__pulse animate__infinite" style="max-width: 220px;">
                                        <div class="fw-bold text-danger mb-1"><i class="bi bi-exclamation-triangle me-1"></i> İade Talebi Var!</div>
                                        <div class="text-dark mb-2"><strong>Neden:</strong> @item.IadeNedeni</div>
            
                                        <div class="d-flex gap-1">
                                            @* IadeOnayla metodu AdminController'da olmalı *@
                                            <form asp-action="IadeOnayla" method="post">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <input type="hidden" name="onay" value="true" />
                                                <button type="submit" class="btn btn-success btn-sm py-0 px-2 fw-bold" style="font-size: 11px;">Onayla</button>
                                            </form>
                                            <form asp-action="IadeOnayla" method="post">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <input type="hidden" name="onay" value="false" />
                                                <button type="submit" class="btn btn-danger btn-sm py-0 px-2 fw-bold" style="font-size: 11px;">Reddet</button>
                                            </form>
                                        </div>
                                    </div>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a href="/Admin/Fatura/@item.Id" target="_blank" class="btn btn-sm btn-outline-primary rounded-pill px-3 shadow-sm">
                                        <i class="bi bi-eye me-1"></i> Fatura
                                    </a>

                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-light border dropdown-toggle rounded-pill" type="button" data-bs-toggle="dropdown">
                                            Durum
                                        </button>
                                        <ul class="dropdown-menu shadow border-0">
                                            <li><form asp-action="GuncelleSiparisDurum" method="post"><input type="hidden" name="id" value="@item.Id" /><input type="hidden" name="yeniDurum" value="Hazırlanıyor" /><button type="submit" class="dropdown-item">Hazırlanıyor</button></form></li>
                                            <li><form asp-action="GuncelleSiparisDurum" method="post"><input type="hidden" name="id" value="@item.Id" /><input type="hidden" name="yeniDurum" value="Kargoya Verildi" /><button type="submit" class="dropdown-item">Kargoya Verildi</button></form></li>
                                            <li><form asp-action="GuncelleSiparisDurum" method="post"><input type="hidden" name="id" value="@item.Id" /><input type="hidden" name="yeniDurum" value="Teslim Edildi" /><button type="submit" class="dropdown-item">Teslim Edildi</button></form></li>
                                            <li><form asp-action="GuncelleSiparisDurum" method="post"><input type="hidden" name="id" value="@item.Id" /><input type="hidden" name="yeniDurum" value="İptal Edildi" /><button type="submit" class="dropdown-item text-danger">İptal Et</button></form></li>
                                        </ul>
                                    </div>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>