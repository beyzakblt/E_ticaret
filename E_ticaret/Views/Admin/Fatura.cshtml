@model E_ticaret.Models.Siparisler
@{
    Layout = null;
    var kullanici = ViewBag.Kullanici as E_ticaret.Models.Kullanicilar;
    var urun = ViewBag.Urun as E_ticaret.Models.Urunler;
    var ayar = ViewBag.Ayar as E_ticaret.Models.SiteAyarlari;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>Fatura Görüntüle - #@Model.Id</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body {
            background: #f4f7f6;
            font-family: 'Inter', sans-serif;
        }

        .invoice-box {
            background: #fff;
            max-width: 850px;
            margin: 30px auto;
            padding: 40px;
            border-radius: 10px;
            box-shadow: 0 0 20px rgba(0,0,0,0.1);
        }

        @* Yazdırırken butonları gizle *@
        @@media print {
            .no-print {
                display: none !important;
            }

            .invoice-box {
                box-shadow: none;
                margin: 0;
                width: 100%;
                max-width: 100%;
            }

            body {
                background: #fff;
            }
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="invoice-box no-print d-flex justify-content-between align-items-center mb-0" style="background: #e9ecef;">
            <span class="fw-bold text-muted"><i class="bi bi-info-circle me-2"></i>Fatura Önizleme Modu</span>
            <div>
                <button onclick="window.print();" class="btn btn-success rounded-pill px-4 shadow-sm">
                    <i class="bi bi-printer me-2"></i>Faturayı Yazdır
                </button>
                <button onclick="window.close();" class="btn btn-light border rounded-pill px-3 ms-2">Kapat</button>
            </div>
        </div>

        <div class="invoice-box">
            <div class="row mb-4">
                <div class="col-6">
                    <h2 class="fw-bold text-primary">@ayar?.SiteAdi</h2>
                    <p class="text-muted small">@ayar?.Adres<br>@ayar?.Tel</p>
                </div>
                <div class="col-6 text-end">
                    <h1 class="display-6 fw-bold text-secondary">FATURA</h1>
                    <p class="mb-0">No: #@Model.Id</p>
                    <p>Tarih: @Model.SiparisTarihi?.ToString("dd.MM.yyyy")</p>
                </div>
            </div>

            <hr>

            <div class="row my-5">
                <div class="col-6">
                    <p class="text-muted mb-1 text-uppercase small fw-bold">Müşteri:</p>
                    <h5 class="fw-bold">@kullanici?.AdSoyad</h5>
                    <p class="text-muted">@kullanici?.Adres<br>@kullanici?.Ilce / @kullanici?.Sehir</p>
                </div>
                <div class="col-6 text-end">
                    <p class="text-muted mb-1 text-uppercase small fw-bold">Ödeme:</p>
                    <p class="fw-bold">Kapıda Ödeme</p>
                </div>
            </div>

            <table class="table table-bordered mt-4">
                <thead class="table-light">
                    <tr>
                        <th>Ürün</th>
                        <th class="text-center">Adet</th>
                        <th class="text-end">Fiyat</th>
                        <th class="text-end">Toplam</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>@urun?.UrunAdi</td>
                        <td class="text-center">@Model.Adet</td>
                        <td class="text-end">@((Model.ToplamFiyat / Model.Adet)?.ToString("C2"))</td>
                        <td class="text-end fw-bold">@Model.ToplamFiyat?.ToString("C2")</td>
                    </tr>
                </tbody>
            </table>

            <div class="row justify-content-end mt-4">
                <div class="col-4 text-end">
                    <div class="d-flex justify-content-between border-bottom py-2">
                        <span>Genel Toplam:</span>
                        <span class="fw-bold text-primary fs-5">@Model.ToplamFiyat?.ToString("C2")</span>
                    </div>
                </div>
            </div>

            <div class="text-center mt-5 pt-5 opacity-50 small">
                Bu bir elektronik faturadır. @DateTime.Now.ToString("yyyy") @ayar?.SiteAdi
            </div>
        </div>
    </div>

</body>
</html>