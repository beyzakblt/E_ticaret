@model List<E_ticaret.Models.Kullanicilar>
@{
    ViewData["Title"] = "Üye Yönetimi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3 d-flex justify-content-between align-items-center">
            <h5 class="fw-bold mb-0 text-dark">
                <i class="bi bi-people-fill me-2 text-primary"></i>Kayıtlı Kullanıcı Yönetimi
            </h5>
            <div class="d-flex gap-2">
                <span class="badge bg-light text-primary border border-primary rounded-pill px-3 py-2 d-none d-md-inline-block">Toplam: @Model.Count Üye</span>
                <button type="button" class="btn btn-primary rounded-pill px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#ekleModal">
                    <i class="bi bi-person-plus-fill me-2"></i>Yeni Üye Ekle
                </button>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4">
        <div class="table-responsive p-3">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Ad Soyad</th>
                        <th>E-Mail</th>
                        <th>Kayıt Tarihi</th>
                        <th>Durum</th>
                        <th class="text-center">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var k in Model)
                    {
                        <tr>
                            <td class="fw-bold">@k.AdSoyad</td>
                            <td>@k.Email</td>
                            <td class="small text-muted">@k.KayitTarihi?.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                @if (k.Durum == true)
                                {
                                    <span class="badge bg-success-soft text-success border border-success px-3">Onaylı</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger-soft text-danger border border-danger px-3">Engelli</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="btn-group shadow-sm rounded-pill overflow-hidden">
                                    <a href="/Admin/KullaniciDurumGuncelle/@k.Id" class="btn btn-sm @(k.Durum == true ? "btn-warning" : "btn-success")" title="Durum Değiştir">
                                        <i class="bi @(k.Durum == true ? "bi-slash-circle" : "bi-check-circle")"></i>
                                    </a>

                                    <button type="button" class="btn btn-sm btn-primary" onclick="duzenleModalAc(@k.Id, '@k.AdSoyad', '@k.Email')" title="Bilgileri Düzenle">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>

                                    <a href="/Admin/KullaniciSil/@k.Id" class="btn btn-sm btn-danger" onclick="return confirm('Bu kullanıcıyı silmek istediğine emin misin?')" title="Kullanıcıyı Sil">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="ekleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <form action="/Admin/KullaniciEkle" method="post">
                <div class="modal-header border-0 bg-primary text-white rounded-top-4 p-4">
                    <h5 class="modal-title fw-bold"><i class="bi bi-person-plus-fill me-2"></i>Yeni Kullanıcı Kaydı</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Ad Soyad</label>
                        <input type="text" name="AdSoyad" class="form-control rounded-3" placeholder="Örn: Beyza Akbulut" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">E-Posta Adresi</label>
                        <input type="email" name="Email" class="form-control rounded-3" placeholder="ornek@mail.com" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Başlangıç Şifresi</label>
                        <input type="password" name="Sifre" class="form-control rounded-3" placeholder="******" required />
                    </div>
                </div>
                <div class="modal-footer border-0 p-3 bg-light rounded-bottom-4">
                    <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 shadow">Kullanıcıyı Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="duzenleModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <form action="/Admin/KullaniciGuncelle" method="post">
                <div class="modal-header border-0 bg-light rounded-top-4">
                    <h5 class="modal-title fw-bold text-dark"><i class="bi bi-pencil-square me-2"></i>Kullanıcı Bilgilerini Güncelle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <input type="hidden" name="Id" id="editId" />

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Ad Soyad</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-person text-muted"></i></span>
                            <input type="text" name="AdSoyad" id="editAd" class="form-control border-start-0 ps-0" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">E-Posta Adresi</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-envelope text-muted"></i></span>
                            <input type="email" name="Email" id="editEmail" class="form-control border-start-0 ps-0" required />
                        </div>
                        <div id="emailHelp" class="form-text text-warning small">Dikkat: E-posta değişikliği kullanıcının giriş bilgilerini etkiler.</div>
                    </div>
                </div>
                <div class="modal-footer border-0 p-3 bg-light rounded-bottom-4">
                    <button type="button" class="btn btn-secondary rounded-pill px-4" data-bs-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 shadow">Değişiklikleri Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function duzenleModalAc(id, ad, email) {
        document.getElementById('editId').value = id;
        document.getElementById('editAd').value = ad;
        document.getElementById('editEmail').value = email;
        var myModal = new bootstrap.Modal(document.getElementById('duzenleModal'));
        myModal.show();
    }
</script>

<style>
    .bg-success-soft {
        background-color: rgba(25, 135, 84, 0.1);
    }

    .bg-danger-soft {
        background-color: rgba(220, 53, 69, 0.1);
    }

    .table-hover tbody tr:hover {
        background-color: rgba(0,0,0,0.02);
    }
</style>