<script>
    // 2. ADIM: JavaScript kodunu form ve editör ID'lerinle eşledik
    document.getElementById('sozlesmeForm').addEventListener('submit', function (e) {

        // Alert her türlü gelsin
        alert("Sözleşme başarıyla kaydedildi!");

        // 3. ADIM: Temizleme işlemi
        setTimeout(() => {
            // Başlığı temizle
            document.getElementById('Baslik').value = "";

            // Editörü temizle (Senin ID'n 'editor' olduğu için düzelttim)
            if (tinymce.get('editor')) {
                tinymce.get('editor').setContent('');
            }
        }, 100);
    });
</script>



